{
  "name": "@matra/core",
  "description": "Domain-neutral AST, parser, visitor, and transformer for Matra",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/parser/grammar.pegjs"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run build:parser && npm run build:types",
    "build:parser": "peggy --format es --output src/parser/generated.mjs src/parser/grammar.pegjs",
    "build:types": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepack": "npm run build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matralang/matra.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "peggy": "^5.0.6",
    "typescript": "^5.9.3"
  }
}
