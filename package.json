{
  "name": "@butchi/matra-core",
  "description": "Matra core language runtime and parser",
  "version": "0.8.1",
  "type": "module",
  "main": "src/index.mjs",
  "types": "dist/types/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.mts",
      "import": "./src/index.mjs"
    }
  },
  "files": [
    "src",
    "dist/types"
  ],
  "scripts": {
    "build": "npm run build:parser && npm run build:types",
    "build:parser": "peggy --format es --output src/parser.mjs src/matra.pegjs",
    "build:types": "tsc",
    "check": "tsc --noEmit",
    "test": "node --test",
    "prepack": "npm run build"
  },
  "license": "MIT",
  "repository": "https://github.com/butchi/matra-core",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "peggy": "^5.0.6",
    "typescript": "^5.9.3"
  }
}
